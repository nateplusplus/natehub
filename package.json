{
  "name": "natehub",
  "version": "0.0.1",
  "description": "My crazy website",
  "main": "index.js",
  "watch": {
    "build-css": {
      "patterns": [
        "scss"
      ],
      "extensions": "scss",
      "legacyWatch": true,
      "runOnChangeOnly": false
    }
  },
  "scripts": {
    "test": "mocha",
    "compile-sass": "node-sass scss/main.scss dist/css/style.css",
    "prefix-css": "postcss --use autoprefixer -b 'last 5 versions' dist/css/style.css -o dist/css/style.prefix.css",
    "compress-css": "node-sass dist/css/style.prefix.css dist/css/style.min.css --output-style compressed --sourceMap=true",
    "build-css": "npm-run-all compile-sass prefix-css compress-css",
    "build-js": "uglifyjs js/script.js --output dist/js/script.min.js",
    "build": "npm-run-all build-js build-css",
    "watch": "npm-watch build-css",
    "serve": "http-server ./"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nateplusplus/natehub.git"
  },
  "keywords": [
    "portfolio",
    "showcase",
    "website",
    "gamify"
  ],
  "author": "@nateplusplus",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nateplusplus/natehub/issues"
  },
  "homepage": "https://github.com/nateplusplus/natehub#readme",
  "dependencies": {
    "phaser": "^3.52.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.2.1",
    "chai": "^4.2.0",
    "compile-sass": "^1.1.1",
    "http-server": "^0.12.3",
    "mocha": "^8.2.1",
    "npm-run-all": "^4.1.5",
    "npm-watch": "^0.7.0",
    "postcss": "^8.2.4",
    "postcss-cli": "^8.3.1",
    "sass": "^1.32.4",
    "uglify-js": "^3.12.4"
  }
}
